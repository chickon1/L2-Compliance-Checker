<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX Toolset v6 source for the per-user Compliance Checker MSI. Packages a
  pre-built compliance-checker.exe -- in CI this is the SignPath-signed exe
  (see .github/workflows/release.yml for the full build/sign sequence);
  locally it's whatever PyInstaller just produced (see packaging/README.md).

  The exe's path is supplied at build time via the SignedExeSource
  preprocessor variable:

    wix build packaging/compliance-checker.wxs -d SignedExeSource=path\to\compliance-checker.exe -out ComplianceChecker.msi

  UpgradeCode below is fixed and must NEVER change across future versions --
  that's what lets Windows Installer recognize "this is an upgrade of an
  existing install" instead of trying to install side-by-side.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="Compliance Checker"
           Manufacturer="Compliance Checker"
           Version="0.1.0"
           UpgradeCode="84B99EB6-EE26-4AD0-A6B7-FFE054FF6B32"
           Scope="perUser">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Compliance Checker is already installed." />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="ComplianceChecker">
        <Component Id="MainExecutable" Guid="*">
          <File Id="ComplianceCheckerEXE" Source="$(var.SignedExeSource)" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Component Id="ApplicationShortcut" Guid="*">
        <Shortcut Id="ApplicationStartMenuShortcut"
                  Name="Compliance Checker"
                  Target="[INSTALLFOLDER]compliance-checker.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveProgramMenuFolder" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\ComplianceChecker" Name="installed" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <Feature Id="MainFeature" Title="Compliance Checker" Level="1">
      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="ApplicationShortcut" />
    </Feature>

  </Package>
</Wix>
